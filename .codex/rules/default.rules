prefix_rule(pattern=["git", "cherry-pick"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden")
prefix_rule(pattern=["git", "push", "-f"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--force-with-lease"], decision="forbidden")
prefix_rule(pattern=["npx", "-y", "@djankies/vitest-mcp"], decision="allow")
prefix_rule(pattern=["npx", "-y", "@playwright/mcp@latest"], decision="allow")
prefix_rule(pattern=["npx", "-y", "mcp-refactor-typescript"], decision="allow")
prefix_rule(pattern=["npx", "-y", "next-devtools-mcp@latest"], decision="allow")

  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase",
    "next-devtools"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Post-compact reminder: Check TaskList for current work. Read MEMORY.md for cross-session context. Re-read any files you need — file contents are lost during compaction.'"
          }
        ]
      }
    ]
  },
  "outputStyle": "default",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "~/chat-buddy.git",
        "~/.local/share/pnpm"
      ]
    }
